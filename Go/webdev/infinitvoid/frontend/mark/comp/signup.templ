package comp


templ Signup(){
    <div class="flex flex-col justify-center items-center">
        <form hx-post="/signup" hx-target="#signuperr" class="fieldset bg-base-200 border-base-300 rounded-box w-xs border p-4">
          <legend class="fieldset-legend">signup</legend>

          <label class="label">name</label>
          <input type="text" class="input" placeholder="name" name="UserName"/>

          <label class="label">Password</label>
          <input type="text" class="input" placeholder="password" name="Password"/>

          <button type="submit" class="btn btn-neutral mt-4">sign up</button>
        </form>
        <h1 id="signuperr" class="text-error"></h1>
    </div>
}